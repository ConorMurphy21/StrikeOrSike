{
  "extends": "../tsconfig.options.json",
  "include": ["src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*", "**/node_modules/**/*"],
  "compilerOptions": {
    "module": "esnext",
    "paths": {
      "@/*": ["./src/*"],
      ":common/*": ["../common/src/*"]
    },
    "types": ["vite/client", "bootstrap", "node"],
    "allowJs": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "noUnusedLocals": false,
    "noImplicitReturns": false
  },
  "references": [
    {
      "path": "../common"
    }
  ]
}
